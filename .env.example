# SmartTex Inventory — Environment Configuration
# Copy this file to .env and fill in real values for production use.

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# Database URL
# Default (development): SQLite, no setup required
# DATABASE_URL=sqlite:///instance/smarttex.db

# Production (MySQL): uncomment and fill in your credentials, then
# pip install PyMySQL  (already listed, commented, in requirements.txt)
# DATABASE_URL=mysql+pymysql://smarttex_user:your_password@localhost:3306/smarttex_inventory

# Flask environment
FLASK_DEBUG=1
